# API
PORT=8787
NODE_ENV=development

# Arc Testnet
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network
ARC_TESTNET_CHAIN_ID=5042002
ARC_REPORT_REGISTRY_ADDRESS=

# x402 seller
X402_ENABLED=false
X402_PROVIDER=mock
X402_PRICE=$0.001
X402_PAY_TO=
X402_ACCEPTED_NETWORKS=eip155:5042002
X402_GATEWAY_FACILITATOR_URL=https://gateway-api-testnet.circle.com
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_CHALLENGE_TTL_MS=300000

# MCP analysis client
MCP_ANALYSIS_MODE=local
AGENTWARDEN_API_URL=http://localhost:8787
X402_PAYER_PRIVATE_KEY=
X402_PAYER_CHAIN=arcTestnet
X402_MAX_PRICE=$0.01
X402_PAYMENT_TIMEOUT_MS=15000
X402_LIVE_TEST=false

# Future optional integrations
ANALYSIS_RPC_URL=
ANALYSIS_RPC_TIMEOUT_MS=3000
SIMULATION_MODE=
ANVIL_RPC_URL=http://127.0.0.1:8545
SIMULATION_TIMEOUT_MS=10000
REPORT_STORE_DIR=
TENDERLY_RPC_URL=
TENDERLY_API_KEY=
GOPLUS_BASE_URL=https://api.gopluslabs.io/api/v1
GOPLUS_ENABLED=false
GOPLUS_API_KEY=
BLOCKSEC_API_KEY=
TRM_API_KEY=
ELLIPTIC_API_KEY=
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
